<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProfile name="!docker">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{30}) - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
        <logger name="com.conceptarena" level="DEBUG" />
    </springProfile>

    <springProfile name="docker">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <!-- O1: valid JSON via LogstashEncoder (proper escaping of quotes/newlines in messages);
                 all MDC keys (requestId, userId, roomId, eventId, eventType, roundId, latencyMs) are
                 included automatically when present. -->
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"service":"game-engine-service"}</customFields>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE" />
        </root>
        <logger name="com.conceptarena" level="INFO" />
    </springProfile>

</configuration>
