{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["conceptarena"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "title": "ConceptArena — Overview",
  "uid": "conceptarena-overview",
  "version": 2,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Services up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }, "overrides": []
      },
      "targets": [ { "refId": "A", "expr": "up{job=\"conceptarena-services\"}", "legendFormat": "{{app}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 2, "type": "timeseries", "title": "Request rate (RPS) by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(rate(http_server_requests_seconds_count{job=\"conceptarena-services\"}[1m])) by (app)", "legendFormat": "{{app}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 3, "type": "timeseries", "title": "p95 HTTP latency by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"conceptarena-services\"}[5m])) by (le, app))", "legendFormat": "{{app}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 4, "type": "timeseries", "title": "Error rate by service (errors_total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(rate(errors_total[5m])) by (service)", "legendFormat": "{{service}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 5, "type": "timeseries", "title": "RabbitMQ ready messages (queue lag) by queue",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "rabbitmq_queue_messages_ready", "legendFormat": "{{queue}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 6, "type": "timeseries", "title": "CPU usage by service (O7)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "process_cpu_usage{job=\"conceptarena-services\"}", "legendFormat": "{{app}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 7, "type": "timeseries", "title": "JVM heap used by service (O8)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(jvm_memory_used_bytes{area=\"heap\",job=\"conceptarena-services\"}) by (app)", "legendFormat": "{{app}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 8, "type": "timeseries", "title": "JVM live threads by service (O8)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "jvm_threads_live_threads{job=\"conceptarena-services\"}", "legendFormat": "{{app}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 9, "type": "timeseries", "title": "JVM GC pause rate by service (O8)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum(rate(jvm_gc_pause_seconds_sum{job=\"conceptarena-services\"}[1m])) by (app)", "legendFormat": "{{app}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 10, "type": "timeseries", "title": "Domain events rate (O9: conceptarena.events.*)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (__name__) (rate({__name__=~\"conceptarena_events_.+\"}[1m]))", "legendFormat": "{{__name__}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Anti-cheat: answers rejected & rounds completed (O9)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "rate(conceptarena_respuestas_rechazadas_total[1m])", "legendFormat": "answers rejected/s", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "rate(conceptarena_rondas_completas_total[1m])", "legendFormat": "rounds completed/s", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "SLO error-budget burn (O11: ratio vs 0.1% budget)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": [ { "matcher": { "id": "byName", "options": "budget (0.1%)" }, "properties": [ { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ]
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(http_server_requests_seconds_count{job=\"conceptarena-services\",outcome=\"SERVER_ERROR\"}[5m])) by (app) / sum(rate(http_server_requests_seconds_count{job=\"conceptarena-services\"}[5m])) by (app)", "legendFormat": "{{app}} error ratio", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "vector(0.001)", "legendFormat": "budget (0.1%)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 13, "type": "stat", "title": "Availability SLI, last 1h (O11)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 3,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.99 }, { "color": "green", "value": 0.999 } ] }
        }, "overrides": []
      },
      "targets": [ { "refId": "A", "expr": "1 - (sum(rate(http_server_requests_seconds_count{job=\"conceptarena-services\",outcome=\"SERVER_ERROR\"}[1h])) by (app) / sum(rate(http_server_requests_seconds_count{job=\"conceptarena-services\"}[1h])) by (app))", "legendFormat": "{{app}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "id": 14, "type": "logs", "title": "Service logs (O10: Loki — filter by requestId to trace a request)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 56 },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none", "sortOrder": "Descending" },
      "targets": [ { "refId": "A", "expr": "{container=~\"conceptarena.*\"}", "datasource": { "type": "loki", "uid": "loki" } } ]
    }
  ]
}
