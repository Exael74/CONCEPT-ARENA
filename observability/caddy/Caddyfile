# D3: Caddy terminates TLS and reverse-proxies to the frontend (nginx), which in turn proxies /api
# and /ws to the api-gateway. WebSocket upgrades are proxied transparently, so /ws/ becomes WSS.
# {$CADDY_SITE} is "localhost" by default (Caddy issues a locally-trusted cert) or a real domain
# (Caddy fetches a Let's Encrypt cert automatically).
{$CADDY_SITE} {
	encode gzip
	reverse_proxy frontend:80
}
