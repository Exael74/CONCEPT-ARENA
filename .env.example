# Copy to .env before running `docker compose up`.
# Must be identical across all 4 services — see ADR-005 (shared HS256 secret) — and at least
# 256 bits (32 chars) long, or JwtValidator will reject it at startup.
# For any non-local deployment generate a random one:  openssl rand -hex 32
JWT_SECRET=conceptarena-dev-secret-key-must-be-at-least-256-bits-long-for-hs256

# Token lifetime in ms (default here: 2h). Kept short because the JWT also rides the
# WebSocket-handshake URL (?token=) — see frontend/nginx.conf (access_log off on /ws/).
JWT_EXPIRATION_MS=7200000

# D2: allowed CORS origins for the api-gateway (comma-separated). Only needed for the SEPARATED
# deploy mode (frontend on a different origin). Defaults to "*" (main compose) / the vite dev origin
# (backend-only compose). Example for production:
# CORS_ORIGINS=https://app.midominio.com

# Grafana admin credentials (main compose observability stack). Defaults to admin/admin.
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=admin

# TLS overlay (docker-compose.tls.yml): the public hostname Caddy serves / gets a cert for.
# CADDY_SITE=conceptarena.midominio.com
