<?xml version="1.0" encoding="UTF-8"?>
<!-- O2: the gateway previously had no logback config, so in Docker its logs were plain text and
     unparseable by Loki. Now it matches the other services: readable console for local dev, valid
     JSON (LogstashEncoder) under the docker profile. -->
<configuration>

    <springProfile name="!docker">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{30}) - %msg%n</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE" />
        </root>
        <logger name="com.conceptarena" level="DEBUG" />
    </springProfile>

    <springProfile name="docker">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"service":"api-gateway"}</customFields>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE" />
        </root>
        <logger name="com.conceptarena" level="INFO" />
    </springProfile>

</configuration>
